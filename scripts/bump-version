#!/usr/bin/env bash
set -euo pipefail

if [ $# -ne 1 ]; then
  echo "Usage: scripts/bump-version <version>" >&2
  echo "Example: scripts/bump-version 0.2.0" >&2
  exit 1
fi

VERSION="$1"

if ! [[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "Error: version must be X.Y.Z" >&2
  exit 1
fi

cd "$(git -C "$(dirname "$0")" rev-parse --show-toplevel)"

sed -i "0,/^version = .*/s//version = \"$VERSION\"/" otter/Cargo.toml
sed -i "0,/^version = .*/s//version = \"$VERSION\"/" otter_codegen/Cargo.toml
sed -i "s/{vsn, \"[^\"]*\"}/{vsn, \"$VERSION\"}/" rebar3_otter/src/rebar3_otter.app.src

echo "Updated to $VERSION:"
grep -Hn "^version" otter/Cargo.toml otter_codegen/Cargo.toml
grep -Hn "vsn" rebar3_otter/src/rebar3_otter.app.src
